---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  active?: "listings" | "map" | "about";
}

const {
  title = "청약 — SH · LH 공공임대 청약 캘린더",
  description = "서울주택도시공사(SH)와 한국토지주택공사(LH)의 공공임대 청약 공고를 한 곳에서. 캘린더와 지도로 한눈에.",
  active = "listings",
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#3182F6" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href="/" class="site-logo">
          <span class="site-logo__dot"></span>
          <span>청약</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href="/listings" class={active === "listings" ? "active" : ""}>목록</a>
          <a href="/map" class={active === "map" ? "active" : ""}>지도</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <style is:global>
      /* additional global styles can go here */
    </style>
  </body>
</html>
